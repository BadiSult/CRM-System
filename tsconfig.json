{
   
  "compilerOptions": {
    "target": "es2016",      
    "lib": ["dom", "dom.iterable", "esnext"],                             
    "module": "commonjs",                                 
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true, 
    "isolatedModules": true,
    "strict": true,
    "noEmit": true,                            
    "forceConsistentCasingInFileNames": true,             
        
     
    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ]                                   
  },
  "include": ["src"]
}
